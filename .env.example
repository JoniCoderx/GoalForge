# ─────────────────────────────────────────────────────────────
# GoalForge AI — Environment configuration
# Copy to server/.env for local development.
# ─────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173

# Auth
# REQUIRED in production — the server refuses to boot with a weak/default secret.
# Generate one with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Comma-separated extra CORS origins allowed in production (e.g. your custom
# domain). CLIENT_URL is always allowed. Same-origin requests need nothing here.
# CORS_ORIGINS=https://goalforge.top,https://www.goalforge.top

# Database
# Local dev uses SQLite; production (Render) uses PostgreSQL.
DATABASE_URL="file:./dev.db"
# Example production value:
# DATABASE_URL="postgresql://user:password@host:5432/goalforge?schema=public"
# Prisma provider. Auto-detected from DATABASE_URL when unset; set explicitly
# to "postgresql" in production (build/start rewrite the schema accordingly).
# DATABASE_PROVIDER=postgresql

# OpenAI — the only paid service required.
# When empty, the app falls back to a deterministic local generator so it
# still works end-to-end without a key.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Storage — "local" today, swappable for "s3"/"gcs" later.
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=storage

# Video rendering
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=60

# Admin bootstrap (created by the seed script)
ADMIN_EMAIL=admin@goalforge.ai
ADMIN_PASSWORD=goalforge123
