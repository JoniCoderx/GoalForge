# ─────────────────────────────────────────────────────────────
# GoalForge AI — Environment configuration
# Copy to server/.env for local development.
# ─────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Database
# Local dev uses SQLite; production (Render) uses PostgreSQL.
DATABASE_URL="file:./dev.db"
# Example production value:
# DATABASE_URL="postgresql://user:password@host:5432/goalforge?schema=public"

# OpenAI — the only paid service required.
# When empty, the app falls back to a deterministic local generator so it
# still works end-to-end without a key.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Storage — "local" today, swappable for "s3"/"gcs" later.
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=storage

# Video rendering
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=60

# Admin bootstrap (created by the seed script)
ADMIN_EMAIL=admin@goalforge.ai
ADMIN_PASSWORD=goalforge123
